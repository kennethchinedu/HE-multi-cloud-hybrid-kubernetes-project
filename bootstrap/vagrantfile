Vagrant.configure("2") do |config|

  config.vm.box = "ubuntu/jammy64"

  # Increase boot timeout — default 300s is too short when booting multiple VMs simultaneously
  config.vm.boot_timeout = 600

  # -------------------------
  # Control Plane
  # -------------------------
  config.vm.define "sre-control-plane" do |cp|
    cp.vm.hostname = "control-plane"
    # private_network gives your Mac direct access to 192.168.56.10
    cp.vm.network "private_network", ip: "192.168.56.10"

    cp.vm.network "forwarded_port", guest: 22,   host: 2222, id: "ssh-cp"
    # kubectl from your Mac → https://127.0.0.1:6443
    # update kubeconfig: kubectl config set-cluster <name> --server=https://127.0.0.1:6443
    cp.vm.network "forwarded_port", guest: 6443, host: 6443, id: "k8s-api"

    cp.vm.provider "virtualbox" do |vb|
      vb.name   = "sre-control-plane"
      vb.memory = 4096
      vb.cpus   = 4
    end
  end

  # -------------------------
  # Worker Node 1
  # -------------------------
  config.vm.define "sre-worker-1" do |w1|
    w1.vm.hostname = "worker-1"
    # NodePorts also reachable directly at 192.168.56.11:<nodeport> from your Mac
    w1.vm.network "private_network", ip: "192.168.56.11"

    w1.vm.network "forwarded_port", guest: 22,  host: 2223, id: "ssh-w1"
    w1.vm.network "forwarded_port", guest: 80,  host: 8080, id: "http-w1"
    w1.vm.network "forwarded_port", guest: 443, host: 8443, id: "https-w1"

    w1.vm.provider "virtualbox" do |vb|
      vb.name   = "sre-worker-1"
      vb.memory = 2048
      vb.cpus   = 2
    end
  end

  # -------------------------
  # Worker Node 2
  # -------------------------
  config.vm.define "sre-worker-2" do |w2|
    w2.vm.hostname = "worker-2"
    w2.vm.network "private_network", ip: "192.168.56.12"

    w2.vm.network "forwarded_port", guest: 22,  host: 2224, id: "ssh-w2"
    w2.vm.network "forwarded_port", guest: 80,  host: 8081, id: "http-w2"
    w2.vm.network "forwarded_port", guest: 443, host: 8444, id: "https-w2"

    w2.vm.provider "virtualbox" do |vb|
      vb.name   = "sre-worker-2"
      vb.memory = 2048
      vb.cpus   = 2
    end
  end


end
